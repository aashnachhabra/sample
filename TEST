      // Bullet points and numbered lists - Enhanced with better spacing and icons
      if (line.match(/^(\d+\.|[-•*]|\([a-z]\))\s/)) {
        const bulletMatch = line.match(/^((\d+\.|[-•*]|\([a-z]\))\s)(.+)$/);
