    const handleGetAiFeedback = async () => {
      const svc = services.find(s => s.name === serviceName);
      if (!svc) return;
      setAiReportLoading(true);
      setAiReport(null);
      setAiReportError(null);
      try {
        const resp = await axios.post(`${baseUrl}/api/vajra/pr-ci-report`, {
          repo_fullname: svc.repoFullname,
          sha: cve.head_sha || undefined,
          include_annotations: true,
          annotations_limit: 50,
          include_actions: true,
          analyze_with_llm: true,
          include_logs: true,
        });
        setAiReport(resp.data);
      } catch (err: any) {
        setAiReportError(err?.response?.data?.detail || err?.message || 'Failed to fetch AI feedback');
      } finally {
        setAiReportLoading(false);
      }
    };

    const handleRefreshCi = async () => {
      if (!cve.head_sha) return;
      const svc = services.find(s => s.name === serviceName);
      if (!svc) return;
      setCiRefreshing(true);
      try {
        const fresh = await fetchCiBuildStatus(svc.repoFullname, cve.head_sha);
        const updatedCve: Vulnerability = { ...cve, ...fresh };
        setModalData({ vulnerability: updatedCve, serviceName });
        setServices(prev => prev.map(s => s.name !== serviceName ? s : {
          ...s,
          cves: s.cves.map(c => c.id === cve.id ? updatedCve : c),
        }));
      } finally {
        setCiRefreshing(false);
      }
    };

