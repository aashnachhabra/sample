    e.dataTransfer.setData('text/plain', JSON.stringify(dragData));
    e.dataTransfer.effectAllowed = 'copy';

    setDragPreview({
      x: e.clientX,
      y: e.clientY,
      data: dragData
    });
  };

  const handleDragEnd = () => {
    setDragPreview(null);
  };

  const handleDragOver = (e: React.DragEvent) => {
    e.preventDefault();
    e.dataTransfer.dropEffect = 'copy';

    if (inputBarRef.current) {
      const rect = inputBarRef.current.getBoundingClientRect();
      const isOverInputBar = e.clientY >= rect.top && e.clientY <= rect.bottom;
      setIsDragOver(isOverInputBar);
    }
  };

  const handleDrop = (e: React.DragEvent) => {
    e.preventDefault();
    setIsDragOver(false);

    try {
      const dragData = JSON.parse(e.dataTransfer.getData('text/plain'));
      const { type, data, serviceName } = dragData;

      const newAttachment: Attachment = {
        id: `${type}-${Date.now()}-${Math.random()}`,
        type,
        data,
        serviceName
      };

      // Check if attachment already exists
      const exists = attachments.some(att => {
        if (att.type === 'service' && type === 'service') {
          return (att.data as Service).name === (data as Service).name;
        }
        if (att.type === 'vulnerability' && type === 'vulnerability') {
          return (att.data as Vulnerability).id === (data as Vulnerability).id && att.serviceName === serviceName;
        }
        return false;
      });

      if (!exists) {
        setAttachments(prev => [...prev, newAttachment]);
      }
    } catch (err) {
      console.error('Failed to parse drag data:', err);
