  const fixCve = async (service: Service, cve: Vulnerability) => {
    const fixKey = `${service.name}-${cve.id}`;
    setLoadingCveFix(fixKey);
    setMessages((prev) => [
      ...prev,
      { sender: 'You', content: `Fix ${cve.id} in ${service.name}` },
    ]);
    try {
      const startResp = await axios.post<AsyncJobStartResponse>(`${baseUrl}/api/vajra/resolve-cve`, {
        cve_id: cve.id,
        service_name: service.name,
        repo_fullname: service.repoFullname,
        build_file_path: service.buildFilePath,
        assigned_email: service.assignedEmail
      });

      const startData = startResp.data;
      setMessages((prev) => [
        ...prev,
        {
          sender: 'AI',
          content: startData?.message || `Started remediation for ${cve.id} in ${service.name}. I will update you once it completes.`,
        },
      ]);

      if (!startData?.job_id) {
        throw new Error('Job ID was not returned from resolve-cve.');
      }

      saveActiveJob(`cve:${fixKey}`, startData.job_id);
      const job = await pollJobUntilDone(startData.job_id);
      const pr_url = job.result?.pr_url || job.pr_url;

      if (pr_url) {
        setMessages((prev) => [
          ...prev,
          {
            sender: 'AI',
            content: (
              <>
                Fixed <strong>{cve.id}</strong> for <strong>{service.name}</strong>. PR created:{' '}
                <a href={pr_url} target="_blank" rel="noreferrer">
                  {pr_url}
                </a>
                . Email sent to {service.assignedEmail}.
              </>
            ),
          },
        ]);
      } else {
        setMessages((prev) => [
          ...prev,
          { sender: 'AI', content: <>No upgradeable dependencies were found for <strong>{cve.id}</strong> in <strong>{service.name}</strong>.</> },
        ]);
      }
      
    } catch (error: unknown) {
      const errorMessage = error instanceof Error ? error.message : 'Unknown error';
      setMessages((prev) => [
        ...prev,
        { sender: 'AI', content: `Oops! Something went wrong while fixing ${cve.id}. (${errorMessage})` },
      ]);
    } finally {
      await refreshService(service.name);
      setLoadingCveFix(null);
      clearActiveJob(`cve:${fixKey}`);
    }
  };

  const fixService = async (service: Service, severity: 'critical' | 'high' = 'critical') => {
    setLoadingFix(service.name);
    setLoadingFixSeverity(severity);
    setMessages((prev) => [
      ...prev,
      { sender: 'You', content: `Fix all ${severity} vulnerabilities in ${service.name}` },
    ]);
    try {
      const startResp = await axios.post<AsyncJobStartResponse>(`${baseUrl}/api/vajra/resolve-all-cves`, {
        service_name: service.name,
        repo_fullname: service.repoFullname,
        build_file_path: service.buildFilePath,
        assigned_email: service.assignedEmail,
        severity,
        simulate: false,
        skip_gradle: false,
        allow_compare_link: true,
      });

      const startData = startResp.data;
      setMessages((prev) => [
        ...prev,
        {
          sender: 'AI',
          content: startData?.message || `Started remediation for all CVEs in ${service.name}. I will update you once it completes.`,
        },
      ]);

      if (!startData?.job_id) {
        throw new Error('Job ID was not returned from resolve-all-cves.');
      }

      saveActiveJob(`svc:${service.name}`, startData.job_id);
      const job = await pollJobUntilDone(startData.job_id);
      const pr_url = job.result?.pr_url || job.pr_url;
      const { no_fix_cves } = job;

      if (!pr_url && no_fix_cves?.length) {
        await Promise.all(
          no_fix_cves.map((cid: string) =>
            axios.post(`${baseUrl}/api/vajra/update-cve-metadata`, {
              service_name: service.name,
              cve_id: cid,
              notes: 'No fix available',
            }),
          ),
        );
      }

      setMessages((prev) => [
        ...prev,
        {
          sender: 'AI',
          content: pr_url ? (
            <>
              Fixed CVEs for <strong>{service.name}</strong>. PR created:{' '}
              <a href={pr_url} target="_blank" rel="noreferrer">
                {pr_url}
              </a>
              . Email sent to {service.assignedEmail}.
            </>
          ) : (
            <>No upgradeable dependencies were found for <strong>{service.name}</strong>.</>
          ),
        },
      ]);

      // Show toast based on job status
      const toastMsg = pr_url
        ? `PR created successfully for ${service.name}`
        : (job.result?.message || job.message || `No upgradeable dependencies found for ${service.name}`);
      setToastMessage(toastMsg);
      setToastSeverity('success');
