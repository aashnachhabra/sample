@router.get("/api/vajra/jobs/{job_id}")
async def get_job_status(job_id: str):
    job = job_status_store.get(job_id)
    if not job:
        raise HTTPException(status_code=404, detail="Job not found")
    return job

job_status_store: dict[str, dict[str, Any]] = {}

@router.post("/api/vajra/resolve-cve")
async def resolve_cve(body: ResolveCVEBody, background_tasks: BackgroundTasks):
    job_id = str(uuid.uuid4())
    job_status_store[job_id] = {
        "status": "started",
        "service_name": body.service_name,
        "cve_id": body.cve_id,
        "started_at": datetime.now().isoformat()
    }
    background_tasks.add_task(_background_resolve_cve, job_id, body)
    return {
        "job_id": job_id,
        "status": "started",
        "message": f"CVE resolution for {body.cve_id} has started",
        "poll_url": f"/api/vajra/jobs/{job_id}"
    }
