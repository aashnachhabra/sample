  const [toastSeverity, setToastSeverity] = useState<'success' | 'error' | 'info'>('info');
  const [loadingCveFix, setLoadingCveFix] = useState<string | null>(null);
  const [autoRefreshServices, setAutoRefreshServices] = useState<Set<string>>(new Set());
  const [loadingResearch, setLoadingResearch] = useState<string | null>(null);

  // Persistent job tracking - survives page refreshes
  // Keys: "svc:<serviceName>" for fix-all, "cve:<serviceName>-<cveId>" for single-CVE fix
  const VAJRA_JOBS_KEY = 'vajra_pr_jobs';
  const [activeJobs, setActiveJobs] = useState<Map<string, string>>(() => {
    try {
      const stored = localStorage.getItem('vajra_pr_jobs');
      return stored ? new Map(JSON.parse(stored)) : new Map();
    } catch { return new Map(); }
  });

  // Search state - Enhanced to search both services and CVEs
  const [searchQuery, setSearchQuery] = useState('');

  // Handle URL parameters on component mount and location changes
  useEffect(() => {
    const searchParam = searchParams.get('search');
    if (searchParam) {
      setSearchQuery(decodeURIComponent(searchParam));
      // Optional: Add a welcome message when coming from ServiceDetail
      setMessages(prev => [
        ...prev,
        {
          sender: 'AI',
          content: `I see you want to resolve vulnerabilities for "${decodeURIComponent(searchParam)}". I've filtered the services for you. You can drag the service card below to attach it to our conversation, or click "Fix Critical CVEs" or "Fix High CVEs" to start the remediation process.`
        },
      ]);
    }
  }, [searchParams, location]);

  // Filter state - Simple assigned filter
  const [assignedFilter, setAssignedFilter] = useState<'me' | 'mes'>('me');

  // Check if there are any vulnerability attachments
  const hasVulnerabilityAttachments = attachments.some(att => att.type === 'vulnerability');

  // Enhanced filtering logic - Simple assigned filter
  const filteredServices = services.filter((service) => {
    const query = searchQuery.toLowerCase();

    // First apply search filter
    let matchesSearch = false;
    if (!query) {
      matchesSearch = true;
    } else {
      // Search by service name
      if (service.name.toLowerCase().includes(query)) {
        matchesSearch = true;
      }
      // Search by CVE ID
      else if (service.cves.some(cve => cve.id.toLowerCase().includes(query))) {
        matchesSearch = true;
      }
      // Search by CVE description
      else if (service.cves.some(cve => cve.description?.toLowerCase().includes(query))) {
        matchesSearch = true;
      }
      // Search by severity
      else if (service.cves.some(cve => cve.severity.toLowerCase().includes(query))) {
        matchesSearch = true;
      }
    }

    if (!matchesSearch) return false;

    // Apply assigned filter
    if (assignedFilter === 'me') {
      return service.assignedEmail === 'sam_ballinger@optum.com';
    } else {
      return service.assignedEmail !== 'sam_ballinger@optum.com';
    }
  });



  // Helper function to check if a CVE matches the search query
  const cveMatchesSearch = (cve: Vulnerability, query: string): boolean => {
    if (!query) return false;
    const lowerQuery = query.toLowerCase();
    return (
      cve.id.toLowerCase().includes(lowerQuery) ||
      cve.description?.toLowerCase().includes(lowerQuery) ||
      cve.severity.toLowerCase().includes(lowerQuery)
    );
  };

  // Helper function to check if CVE needs VAJRA solution
  const isVajraCve = (cve: Vulnerability): boolean => {
    // CVE needs VAJRA if it has AI decision OR lacks fix version
    const hasAiDecision = !!cve.aiDecision;
    const lacksFixVersion = !cve.fixVersion ||
      cve.fixVersion === 'N/A' ||
      cve.fixVersion.toLowerCase().includes('no fixed version');

    return !!(hasAiDecision || lacksFixVersion);
  };

  // UHC Brand Colors
  const uhcColors = {
    blue: '#002677',
    brightBlue: '#00BED5',
    gold: '#F5B700',
    orange: '#FF681F',
  };

  // Solution type colors - VAJRA only
  const solutionColors = {
    'vajra': {
      background: darkMode ? 'rgba(245, 183, 0, 0.15)' : 'rgba(245, 183, 0, 0.1)',
      border: uhcColors.gold,
      accent: uhcColors.gold,
      label: '🤖 VAJRA Solution'
    }
  };

  // Expansion state
  const [expandedCards, setExpandedCards] = useState<Set<string>>(new Set());
  const toggleCardExpand = (name: string) => {
    setExpandedCards((prev) => {
      const set = new Set(prev);
      if (set.has(name)) set.delete(name);
      else set.add(name);
      return set;
    });
  };
  const [expandedCves, setExpandedCves] = useState<Map<string, Set<string>>>(new Map());
  const toggleCveExpand = (serviceName: string, cveId: string) => {
    setExpandedCves((prev) => {
      const newMap = new Map(prev);
      const set = newMap.get(serviceName) || new Set();
      if (set.has(cveId)) set.delete(cveId);
      else set.add(cveId);
      newMap.set(serviceName, set);
      return newMap;
    });
  };

  // Carousel refs
  const railRef = useRef<HTMLDivElement | null>(null);
  const inputBarRef = useRef<HTMLDivElement | null>(null);

  const scrollBy = (direction: 'left' | 'right') => {
    const rail = railRef.current;
    if (!rail) return;
    const cardWidth = rail.firstElementChild
      ? (rail.firstElementChild as HTMLElement).offsetWidth + 16 /* gap */
      : 320;
    rail.scrollBy({ left: direction === 'left' ? -cardWidth : cardWidth, behavior: 'smooth' });
  };

  const baseUrl = process.env.REACT_APP_API_BASE_URL || '';

  const saveActiveJob = (key: string, jobId: string) => {
    setActiveJobs(prev => {
      const next = new Map(prev);
      next.set(key, jobId);
      try { localStorage.setItem(VAJRA_JOBS_KEY, JSON.stringify(Array.from(next.entries()))); } 
      catch {
        console.warn('Failed to save active job to localStorage');
      }
      return next;
    });
  };

  const clearActiveJob = (key: string) => {
    setActiveJobs(prev => {
      const next = new Map(prev);
      next.delete(key);
      try { localStorage.setItem(VAJRA_JOBS_KEY, JSON.stringify(Array.from(next.entries()))); } 
      catch {
        console.warn('Failed to save active job to localStorage');
      }
      return next;
    });
  };

  const wait = (ms: number) => new Promise<void>((resolve) => {
    window.setTimeout(resolve, ms);
  });

  const pollJobUntilDone = async (
    jobId: string,
    timeoutMs = 20 * 60 * 1000,
    intervalMs = 3000,
  ): Promise<AsyncJobStatusResponse> => {
    const startedAt = Date.now();

    while (Date.now() - startedAt < timeoutMs) {
      const resp = await axios.get<AsyncJobStatusResponse>(`${baseUrl}/api/vajra/jobs/${jobId}`);
      const job = resp.data;
      const status = String(job?.status || '').toLowerCase().trim();

      if (['completed', 'complete', 'success', 'succeeded', 'done', 'finished'].includes(status)) {
        return job;
      }

      if (['failed', 'failure', 'error', 'cancelled', 'canceled'].includes(status)) {
        throw new Error(job?.error || job?.message || 'Job failed while resolving CVEs.');
      }

      // Only wait and re-poll when status is non-terminal
      await wait(intervalMs);
    }

    throw new Error('Timed out while waiting for background remediation to finish.');
  };

  // Fetch real CI / build + PR status from the backend
  const fetchCiBuildStatus = async (
    repoFullname: string,
    sha?: string,
    includeActions = false,
  ): Promise<{
    ciStatus: 'passing' | 'failing' | 'pending' | 'unknown';
    ciBuildLog?: string;
    ciRunUrl?: string;
    readyToMerge: boolean;
    prStatus?: 'success' | 'failure' | 'pending';
    ciCheckRuns?: CheckRun[];
  }> => {
    if (!sha) {
      return { ciStatus: 'unknown', ciBuildLog: undefined, ciRunUrl: undefined, readyToMerge: false };
    }
    try {
      const params = new URLSearchParams({
        repo_fullname: repoFullname,
        sha,
        include_actions: String(includeActions),
      });
      const resp = await axios.post<CiData>(`${baseUrl}/api/vajra/ci-status?${params}`);
      const d = resp.data;

      // Map outcome → ciStatus
      const ciStatus: 'passing' | 'failing' | 'pending' | 'unknown' =
        d.outcome === 'success' ? 'passing'
          : d.outcome === 'failure' ? 'failing'
            : d.outcome === 'pending' ? 'pending'
              : 'unknown';

      // Map outcome → prStatus
      const prStatus: 'success' | 'failure' | 'pending' | undefined =
        d.outcome === 'success' ? 'success'
          : d.outcome === 'failure' ? 'failure'
            : d.outcome === 'pending' ? 'pending'
              : undefined;

      // Prefer Actions run URL, fall back to first check run URL
      const ciRunUrl =
        d.actions?.runs?.[0]?.html_url ||
        d.checks?.runs?.[0]?.html_url ||
        undefined;

      // Build log: collect error output from failed check runs and workflow jobs
      const failedChecks = (d.checks?.runs ?? []).filter(
        (cr) => cr.conclusion === 'failure',
      );
      const failedJobs = (d.actions?.runs ?? [])
        .flatMap((run) => run.jobs ?? [])
        .filter((job) => job.conclusion === 'failure');
      const buildLogParts: string[] = [
        ...failedChecks.map((cr) => `[Check] ${cr.name}: ${cr.conclusion}`),
        ...failedJobs.map(
          (job) =>
