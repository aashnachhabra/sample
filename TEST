interface Vulnerability {
  id: string;
  severity: string;
  fixVersion: string | null;
  prUrl: string | null;
  notes: string | null;
  assignee: string;
  description?: string;
  prStatus?: 'success' | 'failure' | 'pending';
  gradleContent?: string;
  aiDecision?: string;
  // New backend fields
  impacted_namespaces: string[];
  package_name?: string;
  package_version?: string;
  status?: string;
  reported_time?: string;
  resolved_time?: string;
  last_pr_created_time?: string;
  gradle_url?: string;
  account_name?: string;
  package_fix?: string;
  product?: string;
  vendor?: string;
  // GitHub Actions CI fields
  ciStatus?: 'passing' | 'failing' | 'pending' | 'unknown';
  ciBuildLog?: string;
  ciRunUrl?: string;
  readyToMerge?: boolean;
  head_sha?: string;
  ciCheckRuns?: CheckRun[];
}

interface Service {
  name: string;
  repoFullname: string;
  buildFilePath: string;
  assignedEmail: string;
  cves: Vulnerability[];
}

interface Attachment {
  id: string;
  type: 'service' | 'vulnerability';
  data: Service | Vulnerability;
  serviceName?: string; // For vulnerability attachments
}

// --- CI Status API types ---
interface CheckRun {
  id: number;
  name: string;
  status: string;
  conclusion: string | null;
  html_url: string;
  started_at?: string;
  completed_at?: string;
}

interface StatusContext {
  context: string;
  state: string;
  target_url: string;
  description: string;
}

interface WorkflowJob {
  name: string;
  status: string;
  conclusion: string | null;
  started_at: string;
  completed_at: string;
  html_url: string;
  steps: { name: string; status: string; conclusion: string | null }[];
}

interface WorkflowRun {
  id: number;
  name: string;
  event: string;
  status: string;
  conclusion: string | null;
  html_url: string;
  jobs: WorkflowJob[];
}

interface CiData {
  ref_sha: string;
  outcome: 'success' | 'failure' | 'pending';
  checks: { total: number; runs: CheckRun[]; error?: string };
  statuses: { state: string; contexts: StatusContext[]; error?: string };
  actions: { runs: WorkflowRun[]; error?: string };
}

interface AsyncJobStartResponse {
  job_id: string;
  status: string;
  message?: string;
  poll_url?: string;
}

interface AsyncJobStatusResponse {
  status: string;
  service_name?: string;
  cve_id?: string;
  pr_url?: string;
  no_fix_cves?: string[];
  message?: string;
  error?: string;
  result?: {
    pr_url?: string;
    [key: string]: any;
  };
}

