                  fontSize: '0.7rem',
                }}
                onClick={() => {
                  setInput(q);
                  handleSend();
                }}
              >
                {q}
              </Button>
            ))}

          </Box>

          {/* Input bar with attachments */}
          <Box
            ref={inputBarRef}
            sx={{
              display: 'flex',
              flexDirection: 'column',
              gap: 1,
              transition: 'all 300ms ease',
              ...(isDragOver && {
                background: 'rgba(255, 140, 0, 0.1)',
                borderRadius: 2,
                p: 1,
                border: `2px dashed ${theme.accent}`,
                transform: 'scale(1.02)',
                boxShadow: `0 0 20px rgba(255, 140, 0, 0.3)`,
              })
            }}
          >
            {/* Attachments display */}
            {attachments.length > 0 && (
              <Fade in={attachments.length > 0}>
                <Box sx={{
                  display: 'flex',
                  flexWrap: 'wrap',
                  gap: 1,
                  p: 1,
                  background: darkMode ? 'rgba(255, 140, 0, 0.1)' : 'rgba(255, 140, 0, 0.05)',
                  borderRadius: 2,
                  border: `1px solid ${darkMode ? 'rgba(255, 140, 0, 0.3)' : 'rgba(255, 140, 0, 0.2)'}`,
                }}>
                  {attachments.map((attachment, index) => (
                    <Zoom in={true} key={attachment.id} style={{ transitionDelay: `${index * 100}ms` }}>
                      <Chip
                        icon={attachment.type === 'service' ? <SecurityIcon /> : <BugReportIcon />}
                        label={
                          attachment.type === 'service'
                            ? (attachment.data as Service).name
                            : `${(attachment.data as Vulnerability).id} (${attachment.serviceName})`
                        }
                        onDelete={() => removeAttachment(attachment.id)}
                        deleteIcon={<CloseIcon />}
                        sx={{
                          background: `linear-gradient(45deg, ${theme.accent}, rgba(255, 140, 0, 0.8))`,
                          color: darkMode ? '#000' : '#fff',
                          fontWeight: 600,
                          '& .MuiChip-deleteIcon': {
                            color: darkMode ? 'rgba(0, 0, 0, 0.7)' : 'rgba(255, 255, 255, 0.7)',
                            '&:hover': {
                              color: darkMode ? '#000' : '#fff',
                            }
                          },
                          '& .MuiChip-icon': {
                            color: darkMode ? 'rgba(0, 0, 0, 0.8)' : 'rgba(255, 255, 255, 0.8)',
                          },
                          animation: 'glow 2s ease-in-out infinite alternate',
                          '@keyframes glow': {
                            '0%': { boxShadow: `0 0 5px ${theme.accent}` },
                            '100%': { boxShadow: `0 0 15px ${theme.accent}, 0 0 25px ${theme.accent}` },
                          },
                        }}
                      />
                    </Zoom>
                  ))}
                </Box>
              </Fade>
            )}

            {/* Input field and buttons */}
            <Box sx={{ display: 'flex', gap: 1 }}>
              <TextField
                fullWidth
                variant="outlined"
                placeholder={isDragOver ? "Drop your attachment here!" : "Ask me anything or drag a service/CVE here..."}
                value={input}
                onChange={(e) => setInput(e.target.value)}
                onKeyDown={(e) => {
                  if (e.key === 'Enter' && !loadingChat) handleSend();
                }}
                disabled={loadingChat}
                sx={{
                  '& .MuiInputBase-input': { color: theme.cardContent, fontSize: '0.8rem' },
                  '& .MuiOutlinedInput-root fieldset': {
                    borderColor: isDragOver ? theme.accent : (darkMode ? '#5558a9' : '#ccc'),
                    transition: 'border-color 300ms ease',
                  },
                  '& .MuiOutlinedInput-root:hover fieldset': { borderColor: darkMode ? '#8fa3ff' : '#888' },
                  '& .MuiOutlinedInput-root.Mui-focused fieldset': { borderColor: darkMode ? '#8fa3ff' : '#555' },
                  background: isDragOver ? 'rgba(255, 140, 0, 0.05)' : (darkMode ? '#2f2a5a' : '#f0f0f0'),
                  borderRadius: 2,
                  transition: 'background-color 300ms ease',
                }}
              />
              <Button
                variant="contained"
                sx={{
                  background: darkMode
                    ? 'linear-gradient(45deg, #ff8c00, #bf6d00)'
                    : 'linear-gradient(45deg, #ff8c00, #bf6d00)',
                  color: darkMode ? '#000' : '#fff',
                }}
                disabled={loadingChat}
                onClick={handleSend}
              >
                Send
              </Button>

              {/* Research Mode Button - Only show if vulnerability attachments exist */}
              {hasVulnerabilityAttachments && (
                <Button
                  variant="outlined"
                  sx={{
                    textTransform: 'none',
                    borderColor: '#ff8c00',
                    color: '#ff8c00',
                    background: darkMode ? 'rgba(255, 140, 0, 0.1)' : 'rgba(255, 140, 0, 0.05)',
                    '&:hover': {
                      background: darkMode ? 'rgba(255, 140, 0, 0.2)' : 'rgba(255, 140, 0, 0.1)',
                      borderColor: '#ff8c00',
                      transform: 'translateY(-1px)',
                      boxShadow: '0 4px 12px rgba(255, 140, 0, 0.3)',
                    },
                    transition: 'all 200ms ease',
                    fontWeight: 600,
                    animation: 'researchGlow 2s ease-in-out infinite alternate',
                    '@keyframes researchGlow': {
                      '0%': { boxShadow: '0 0 5px rgba(255, 140, 0, 0.3)' },
                      '100%': { boxShadow: '0 0 15px rgba(255, 140, 0, 0.5), 0 0 25px rgba(255, 140, 0, 0.3)' },
                    },
                  }}
                  disabled={loadingChat}
                  onClick={() => handleResearchMode()}
                  startIcon={<SearchIcon />}
                >
                  Research Mode
                </Button>
              )}
            </Box>
          </Box>
        </Box>

        {/* Add the modal components */}
        {ServiceModal()}
        <VulnerabilityModal />

        {/* Toast notification */}
        <Snackbar
          open={toastOpen}
          autoHideDuration={5000}
          onClose={(_event, reason) => {
            if (reason === 'clickaway') return;
            setToastOpen(false);
          }}
          anchorOrigin={{ vertical: 'top', horizontal: 'right' }}
          sx={{ mt: '70px' }}
        >
          <Alert
            onClose={() => setToastOpen(false)}
            severity={toastSeverity}
            variant="filled"
            sx={{ width: '100%' }}
          >
            {toastMessage}
          </Alert>
        </Snackbar>
      </Box>
    </div>
  );
};

