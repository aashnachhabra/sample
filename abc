# ---------------------------------------------------------------------------
def _is_logged_in_successfully(page):
    if _is_login_page(page):
        return False
    try:
        _wait_any_selector(page, DASHBOARD_READY_SELECTORS, timeout_ms=10000)
        return True
    except:
        return False

def ensure_logged_in(page, target_url=None):
    logger.info("🔍 Checking login state...")

    try:
        page.wait_for_load_state("networkidle", timeout=10000)
    except Exception:
        pass
    page.wait_for_timeout(2000)

    if _is_login_page(page):
        logger.info(f"  🔐 Login page detected via URL: {page.url[:80]}")
        azure_login(page, target_url=target_url)
        return

    for sel in USERNAME_SELECTORS:
        try:
            if page.locator(sel).first.is_visible(timeout=1000):
                logger.info(f"  🔐 Login form detected via selector: {sel}")
                azure_login(page, target_url=target_url)
                return
        except Exception:
            continue

    if _is_logged_in_successfully(page):
        logger.info("  ✅ Dashboard accessible — login confirmed")
    else:
        logger.warning("  ⚠️ Not confident login succeeded — forcing login")
        azure_login(page, target_url=target_url)
