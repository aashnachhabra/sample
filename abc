def insert_data_to_mongo(standard_table_data, existing_records):
    collection = get_collection()
    try:
        if not standard_table_data and not existing_records:
            logging.info("No existing records found in MongoDB and no data to insert.")
            return

        if existing_records and not standard_table_data:
            _mark_records_fixed(collection, existing_records)
            return

        if not existing_records and standard_table_data:
            operations = []
            for record in standard_table_data:
                unique_id = record.get("unique_id")
                if not unique_id:
                    continue
                operations.append(
                    UpdateOne(
                        {"unique_id": unique_id},
                        {"$set": record},
                        upsert=True
                    )
                )
            if operations:
                collection.bulk_write(operations, ordered = False)
                logging.info(f"✅ MongoDB write completed")
                logging.info(f"Inserted: {result.upserted_count}")
                logging.info(f"Modified: {result.modified_count}")
                logging.info(f"Matched: {result.matched_count}")
                return
        if existing_records and standard_table_data:
            _process_records(collection, standard_table_data, existing_records)
    except BulkWriteError as bwe:
        logging.error(f"Bulk write error: {bwe.details}")
        raise
    except Exception as e:
        logging.error(f"Error inserting data into MongoDB: {e}")
        raise

def _mark_records_fixed(collection, records):
    for unique_id in records:
        collection.update_one(
            {"unique_id": unique_id},
            {"$set": {"status": "D", "resolved_time": time.strftime("%Y-%m-%d %H:%M:%S")}}
        )

def _process_records(collection, standard_table_data, existing_records):
    current_file_ids = set()
    operations = []

    for standard_record in standard_table_data:
        unique_id = standard_record.get("unique_id")
        if not unique_id:
            continue
        current_file_ids.add(unique_id)
        if not standard_record.get("resolved_time"):
            standard_record["resolved_time"] = ""
        if not standard_record.get("status"):
            standard_record["status"] = "NS"
        operations.append(
            UpdateOne(
                {"unique_id": unique_id},
                {"$set": standard_record},
                upsert=True
            )
        )
    if operations:
        result = collection.bulk_write(operations, ordered=False)
        logging.info(f"✅ Bulk update done")
        logging.info(f"Upserted: {result.upserted_count}, Modified: {result.modified_count}")

    records_to_mark_fixed = existing_records - current_file_ids
    print(f'record to be marked fixed: {records_to_mark_fixed}')

    if records_to_mark_fixed:
        for unique_id in records_to_mark_fixed:
            collection.update_one(
                {"unique_id": unique_id},
                {"$set": {"status": "D", "resolved_time": time.strftime("%Y-%m-%d %H:%M:%S")}}
            )

