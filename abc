]

# ---------------------------------------------------------------------------
# PAGE-STATE HELPERS
# ---------------------------------------------------------------------------

def _is_login_page(page) -> bool:
    return any(d in page.url for d in LOGIN_DOMAINS)


def _is_on_password_step(page) -> bool:
    """True when MS has already advanced past the username step.

    On the password screen MS keeps loginfmt in the DOM but adds
    'moveOffScreen' to its class list.  Playwright's is_visible() still
    returns True for such elements (they retain a bounding box), so we
    check via JavaScript rather than Playwright's visibility API.
    """
    try:
        return page.evaluate(
            "() => {"
            "  const el = document.querySelector('input[name=\"loginfmt\"]');"
            "  return el ? el.className.includes('moveOffScreen') : false;"
            "}"
        )
    except Exception:
        return False


def _get_prefilled_username(page) -> str:
    """Return the username MS has pre-filled (stored in the hidden 'login' field)."""
    try:
        return page.evaluate(
            "() => {"
            "  const el = document.querySelector('input[name=\"login\"]');"
            "  return el ? el.value : '';"
            "}"
        ) or ""
    except Exception:
        return ""

# ---------------------------------------------------------------------------
# SELECTOR HELPERS
# ---------------------------------------------------------------------------

USERNAME_SELECTORS = [
    'input[name="loginfmt"]',
    'input[type="email"]',
    'input[name="email"]',
    'input[name="username"]',
    'input[id="username"]',
    'input[id="email"]',
]

PASSWORD_SELECTORS = [
    'input[name="passwd"]',
    'input[id="i0118"]',
    'input[name="password"]',
    'input[id="password"]',
    'input[type="password"]',
]

SUBMIT_SELECTORS = [
    'input[id="idSIButton9"]',
    'input[type="submit"]',
    'button[type="submit"]',
    'button:has-text("Sign in")',
    'button:has-text("Next")',
    'button:has-text("Log in")',
]


def _fill_first_visible(page, selectors, value, label):
    for sel in selectors:
        try:
            loc = page.locator(sel).first
            if loc.is_visible(timeout=2000):
                loc.fill(value)
                logger.info(f"  ✏️  Filled required field")
                return True
        except Exception:
            continue
    return False


def _click_first_visible(page, selectors, label):
    for sel in selectors:
        try:
            loc = page.locator(sel).first
            if loc.is_visible(timeout=2000):
                loc.click()
                logger.info(f"  🖱️  Clicked {label} via: {sel}")
                return True
        except Exception:
            continue
    return False

# ---------------------------------------------------------------------------
# DEBUG
# ---------------------------------------------------------------------------

def _capture(page, label):
    try:
        os.makedirs(DEBUG_DIR, exist_ok=True)
        try:
            title = page.title()
        except Exception:
            title = "n/a"
        logger.info(f"  📸 [{label}] {page.url[:100]}  title={title!r}")
        page.screenshot(path=os.path.join(DEBUG_DIR, f"{label}.png"), full_page=True)
        with open(os.path.join(DEBUG_DIR, f"{label}.html"), "w") as f:
            f.write(page.content())
    except Exception as e:
        logger.warning(f"  Could not save debug snapshot '{label}': {e}")


def _wait_any_selector(page, selectors, timeout_ms=30000):
    """Return the first selector that appears, else raise TimeoutError."""
    deadline = time.time() + (timeout_ms / 1000)
    last_error = None
    while time.time() < deadline:
        for sel in selectors:
            try:
                loc = page.locator(sel).first
                if loc.count() > 0 and loc.is_visible():
                    return sel
            except Exception as exc:
                last_error = exc
                continue
        page.wait_for_timeout(500)
    if last_error:
        raise TimeoutError(f"None of selectors appeared in {timeout_ms}ms. Last error: {last_error}")
    raise TimeoutError(f"None of selectors appeared in {timeout_ms}ms")

# ---------------------------------------------------------------------------
# LOGIN FLOW SUB-STEPS
# ---------------------------------------------------------------------------

def _do_username_step(page):
    """Wait for a real (non-offscreen) username field, fill it, and submit."""
    try:
        page.wait_for_function(
            "() => {"
            "  const el = document.querySelector('input[name=\"loginfmt\"]');"
            "  return el && !el.className.includes('moveOffScreen');"
            "}",
            timeout=8000,
        )
    except Exception:
        pass

    if not _fill_first_visible(page, USERNAME_SELECTORS, USERNAME, "username"):
        _capture(page, "02b-username-not-found")
        raise RuntimeError("Could not find username field — see tmp/debug/02b-*.png")

    if not _click_first_visible(page, SUBMIT_SELECTORS, "submit-after-username"):
        logger.warning("  No submit button — pressing Enter")
        page.keyboard.press("Enter")

    try:
        page.wait_for_load_state("domcontentloaded", timeout=8000)
    except Exception:
        pass
    page.wait_for_timeout(2000)


def _do_password_step(page):
    """Fill the password field and submit."""
    _capture(page, "03-before-password")

    if not _fill_first_visible(page, PASSWORD_SELECTORS, PASSWORD, "password"):
        _capture(page, "04-password-not-found")
        raise RuntimeError("Could not find password field — see tmp/debug/04-*.png")

    if not _click_first_visible(page, SUBMIT_SELECTORS, "submit-after-password"):
        logger.warning("  No submit button — pressing Enter")
        page.keyboard.press("Enter")


def _do_kmsi(page):
    """Handle the 'Stay signed in?' prompt after successful login."""
    try:
        page.wait_for_load_state("domcontentloaded", timeout=5000)
        page.wait_for_timeout(2000)
        _capture(page, "04b-kmsi-check")
        if _is_login_page(page):
            logger.info("  🔑 Still on MS domain — looking for KMSI prompt")
            if _click_first_visible(
                page,
                ['input[id="idSIButton9"]', 'input[value="Yes"]', 'button:has-text("Yes")'],
                "KMSI-Yes",
            ):
                logger.info("  ✅ KMSI Yes clicked")
            elif _click_first_visible(
                page,
                ['input[id="idBtn_Back"]', 'input[value="No"]', 'button:has-text("No")'],
                "KMSI-No",
            ):
                logger.info("  ✅ KMSI No clicked")
    except Exception as exc:
        logger.warning(f"  KMSI step skipped: {exc}")


def _wait_for_platform(page, target_url=None):
    """Wait for the OAuth redirect back to the security platform."""
    try:
        page.wait_for_load_state("networkidle", timeout=15000)
    except Exception:
        pass
    page.wait_for_timeout(5000)
    _capture(page, "05-after-login")

    if _is_login_page(page) and target_url:
        logger.warning(f"  ⚠️  Still on MS login — force-navigating to {target_url}")
        page.goto(target_url)
        try:
            page.wait_for_load_state("networkidle", timeout=15000)
        except Exception:
            pass
        _capture(page, "06-after-forced-redirect")

# ---------------------------------------------------------------------------
# MAIN LOGIN FUNCTION  (fixed — no more double-submit)
# ---------------------------------------------------------------------------

def azure_login(page, target_url=None):
    logger.info("🔐 Performing login")
    _capture(page, "01-login-start")

    if _is_on_password_step(page):
        # MS has already advanced to the password screen.
        # The loginfmt field is still in the DOM but has class 'moveOffScreen'.
        prefilled = _get_prefilled_username(page)
        logger.info(f"  🔑 Already on password step. Pre-filled account: {prefilled!r}")

        if prefilled.lower() == USERNAME.lower():
            # Correct account pre-selected — go straight to password
            logger.info("  ✅ Account matches SECURITY_USERNAME — filling password directly")
        else:
            # WRONG account pre-filled.
            # Click Back to return to the username step, then enter our credentials.
            logger.info(f"  ↩️  {prefilled!r} != SECURITY_USERNAME — clicking Back")
            back_found = _click_first_visible(
                page,
                ['button#idBtn_Back', 'input#idBtn_Back', 'button.backButton'],
                "Back",
            )
            if back_found:
                try:
                    page.wait_for_load_state("domcontentloaded", timeout=8000)
                except Exception:
                    pass
                page.wait_for_timeout(2000)
                _capture(page, "02-after-back")
                _do_username_step(page)
            else:
                # Back button not found — fill both fields at once and submit once.
                # This avoids the double-submit (empty-password) bug.
                logger.warning("  ⚠️  No Back button — filling username+password together")
                _fill_first_visible(page, USERNAME_SELECTORS, USERNAME, "username(combined)")
                _fill_first_visible(page, PASSWORD_SELECTORS, PASSWORD, "password(combined)")
                _click_first_visible(page, SUBMIT_SELECTORS, "submit(combined)")
                _do_kmsi(page)
                _wait_for_platform(page, target_url)
                return
    else:
        # Clean username screen — normal sequential flow
        logger.info("  📝 On username step — doing normal flow")
        _do_username_step(page)

    _do_password_step(page)
    _do_kmsi(page)
    _wait_for_platform(page, target_url)
    if _is_login_page(page):
        logger.error("❌ Login FAILED — still on Microsoft login page")
    else:
        logger.info(f"✅ Login flow finished — landed on: {page.url}")


