def clean_description(description):
    if not isinstance(description, str) or description.lower() in ["n/a", "nan", ""]:
        return "N/A"
    return description.strip('"')

def clean_cve_id(cve_id, description):
    if not isinstance(cve_id, str) or description.lower() in ["n/a", "nan", ""]:
        return "N/A"
    return description.strip('"')

def clean_service_name(instance):
    if isinstance(instance, float) and pd.isna(instance):
        return "N/A"
    if isinstance(instance, str):
        if instance.lower() in ["n/a", "nan", ""]:
            return "N/A"
        if instance.startswith('"') and instance.endswith('"'):
            parts = [p.strip() for p in instance.strip('"').split(',')]
            instance = parts[-1] if parts else instance
        match = re.search(r'/([^/:]+):', instance)
        if match:
            return match.group(1)
    return instance

def edit_downloaded_cloud_vulnerabilities_file():
    dict_complete_list = []
