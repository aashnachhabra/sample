name: Scan All Service Dependencies (Batched)

on:
  workflow_dispatch:
    inputs:
      repo_names:
        description: 'Comma-separated list of repo names (e.g., mes-eventhub-poc-service,mes-another-service) or leave empty for all'
        required: false
        default: ''
      branch:
        description: 'Branch to scan'
        required: false
        default: 'master'
      batch_size:
        description: 'Number of repos to process per batch (default: 15)'
        required: false
        default: '15'
  
  schedule:
    # Run weekly on Sundays at 2 AM UTC
    - cron: '0 2 * * 0'

# Explicit permissions for security (CodeQL requirement)
permissions:
  contents: read      # Read repository code
  actions: read       # Read workflow artifacts

jobs:
  discover-repos:
    runs-on: ubuntu-latest
    outputs:
      repos: ${{ steps.list-repos.outputs.repos }}
      total_count: ${{ steps.list-repos.outputs.total_count }}
    
    steps:
      - name: List repositories to scan
        id: list-repos
        env:
          GITHUB_TOKEN: ${{ secrets.ORG_PAT }}
        run: |
          # If specific repos provided, use those
          if [ -n "${{ github.event.inputs.repo_names }}" ]; then
            echo "Using provided repo list: ${{ github.event.inputs.repo_names }}"
            REPOS=$(echo "${{ github.event.inputs.repo_names }}" | jq -R -s -c 'split(",") | map(ltrimstr(" ") | rtrimstr(" "))')
            TOTAL=$(echo "$REPOS" | jq 'length')
            echo "repos=$REPOS" >> $GITHUB_OUTPUT
            echo "total_count=$TOTAL" >> $GITHUB_OUTPUT
            exit 0
          fi
          
          # Otherwise, auto-discover repos with build.gradle
          echo "Auto-discovering repositories with build.gradle..."
          
          # List all repos in the org
          ALL_REPOS=$(gh api \
            -H "Accept: application/vnd.github+json" \
            -H "X-GitHub-Api-Version: 2022-11-28" \
            /orgs/uhc-tech-medicare-retiree-medicare/repos \
            --paginate \
            --jq '.[].name')
          
          echo "Found repositories in org"
          
          # Filter for repos starting with "mes-" or "mrcp-"
          FILTERED_REPOS=$(echo "$ALL_REPOS" | grep -E '^(mes-|mrcp-)' || true)
          
          if [ -z "$FILTERED_REPOS" ]; then
            echo "No service repos found"
            echo "repos=[]" >> $GITHUB_OUTPUT
            echo "total_count=0" >> $GITHUB_OUTPUT
            exit 0
          fi
          
          # Check each repo for build.gradle (in parallel batches)
          REPOS_WITH_GRADLE="[]"
          COUNT=0
          
          for repo in $FILTERED_REPOS; do
            echo "Checking $repo for build.gradle..."
            
            # Check if build.gradle exists
            if gh api \
              -H "Accept: application/vnd.github+json" \
              /repos/uhc-tech-medicare-retiree-medicare/$repo/contents/build.gradle \
              --silent 2>/dev/null; then
              
              echo "✅ $repo has build.gradle"
              REPOS_WITH_GRADLE=$(echo "$REPOS_WITH_GRADLE" | jq --arg repo "$repo" '. + [$repo]')
              COUNT=$((COUNT + 1))
            else
              echo "⏭️  $repo has no build.gradle, skipping"
            fi
          done
          
          echo "📊 Total repos to scan: $COUNT"
          echo "repos=$REPOS_WITH_GRADLE" >> $GITHUB_OUTPUT
          echo "total_count=$COUNT" >> $GITHUB_OUTPUT

  create-batches:
    needs: discover-repos
    if: needs.discover-repos.outputs.repos != '[]'
    runs-on: ubuntu-latest
    outputs:
      batches: ${{ steps.create-batches.outputs.batches }}
      batch_count: ${{ steps.create-batches.outputs.batch_count }}
    
    steps:
      - name: Create batches
        id: create-batches
        run: |
          REPOS='${{ needs.discover-repos.outputs.repos }}'
          BATCH_SIZE=${{ github.event.inputs.batch_size || 15 }}
          
          echo "Creating batches of $BATCH_SIZE repos..."
          
          # Split repos into batches using jq
          BATCHES=$(echo "$REPOS" | jq -c --argjson size "$BATCH_SIZE" '
            [range(0; length; $size) as $i | .[$i:$i+$size]]
          ')
          
          BATCH_COUNT=$(echo "$BATCHES" | jq 'length')
          
          echo "📦 Created $BATCH_COUNT batches"
          echo "batches=$BATCHES" >> $GITHUB_OUTPUT
          echo "batch_count=$BATCH_COUNT" >> $GITHUB_OUTPUT

  scan-batch:
    needs: [discover-repos, create-batches]
    runs-on: ubuntu-latest
    strategy:
      matrix:
        batch: ${{ fromJson(needs.create-batches.outputs.batches) }}
      fail-fast: false
      max-parallel: 1  # Process one batch at a time to prevent API overload
    
    steps:
      - name: Process repos in batch
        env:
          VAJRA_API_ENDPOINT: ${{ secrets.VAJRA_API_ENDPOINT }}
          GITHUB_TOKEN: ${{ secrets.ORG_PAT }}
        run: |
          REPOS='${{ toJson(matrix.batch) }}'
          BRANCH="${{ github.event.inputs.branch || 'master' }}"
          
          echo "🚀 Starting batch processing"
          echo "Repos in this batch: $REPOS"
          
          # Process each repo in the batch
          echo "$REPOS" | jq -r '.[]' | while read -r repo; do
            echo ""
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            echo "📦 Processing: $repo"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            
            # Clone the repo
            echo "📥 Cloning $repo..."
            if ! gh repo clone uhc-tech-medicare-retiree-medicare/$repo /tmp/$repo -- --depth=1 --branch=$BRANCH 2>/dev/null; then
              echo "❌ Failed to clone $repo, skipping"
              continue
            fi
            
            cd /tmp/$repo
            
            # Check for gradlew
            if [ ! -f "./gradlew" ]; then
              echo "⚠️  No gradlew found in $repo, skipping"
              cd /tmp
              rm -rf $repo
              continue
            fi
            
            # Make gradlew executable
            chmod +x ./gradlew
            
            # Generate dependency tree
            echo "🔍 Generating dependency tree..."
            if ! ./gradlew dependencies --configuration runtimeClasspath > deps-output.txt 2>&1; then
              echo "❌ Gradle command failed for $repo"
              cat deps-output.txt
              cd /tmp
              rm -rf $repo
              continue
            fi
            
            # Get metadata
            COMMIT_SHA=$(git rev-parse HEAD)
            TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
            DEPS_CONTENT=$(cat deps-output.txt)
            
            # Create JSON payload using jq for proper escaping
            GRADLE_JSON=$(echo "$DEPS_CONTENT" | jq -Rs .)
            
            jq -n \
              --arg service "$repo" \
              --arg branch "$BRANCH" \
              --arg commit "$COMMIT_SHA" \
              --argjson gradle "$GRADLE_JSON" \
              --arg timestamp "$TIMESTAMP" \
              '{
                service_name: $service,
                branch: $branch,
                commit_sha: $commit,
                gradle_output: $gradle,
                exported_at: $timestamp
              }' > payload.json
            
            # Validate JSON
            if ! jq empty payload.json 2>/dev/null; then
              echo "❌ Invalid JSON generated for $repo"
              cd /tmp
              rm -rf $repo
              continue
            fi
            
            # Send to API
            echo "📤 Sending to VAJRA API..."
            RESPONSE=$(curl -X POST "$VAJRA_API_ENDPOINT" \
              -H "Content-Type: application/json" \
              -d @payload.json \
              -w "\n%{http_code}" \
              -s \
              --max-time 30)
            
            HTTP_CODE=$(echo "$RESPONSE" | tail -n1)
            BODY=$(echo "$RESPONSE" | head -n-1)
            
            if [ "$HTTP_CODE" -ge 200 ] && [ "$HTTP_CODE" -lt 300 ]; then
              echo "✅ Successfully processed $repo"
            else
              echo "❌ API request failed for $repo (HTTP $HTTP_CODE)"
              echo "Response: $BODY"
            fi
            
            # Cleanup
            cd /tmp
            rm -rf $repo
            
            # Small delay between repos to prevent hammering the API
            echo "⏳ Cooling down (2 seconds)..."
            sleep 2
          done
          
          echo ""
          echo "✅ Batch complete!"
          
          # Delay between batches
          echo "⏸️  Waiting 30 seconds before next batch..."
          sleep 30
      
      - name: Batch completion summary
        if: always()
        run: |
          echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
          echo "📊 Batch processing completed"
          echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  summary:
    needs: [discover-repos, create-batches, scan-batch]
    if: always()
    runs-on: ubuntu-latest
    
    steps:
      - name: Workflow summary
        run: |
          echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
          echo "📊 VAJRA Dependency Scan Summary"
          echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
          echo "Total repos discovered: ${{ needs.discover-repos.outputs.total_count }}"
          echo "Batches processed: ${{ needs.create-batches.outputs.batch_count }}"
          echo "Batch size: ${{ github.event.inputs.batch_size || 15 }}"
