            record_to_dict["description"] = clean_field(record_to_dict.get("description"))
            record_to_dict["fix_version"] = clean_field(record_to_dict.get("fix_version", ""))
            # record_to_dict["namespace"] = clean_field(str(record_to_dict.get("namespace", "")).strip())
            details = str(df.loc[df.index[idx], "Package Details"])
            package_name, package_version, service_name = extract_package_details(details)
            record_to_dict["package_name"] = package_name
            record_to_dict["package_version"] = package_version
            record_to_dict["service_name"] = service_name
        dict_complete_list.extend(dict_list)

    logging.info(f"Total records processed: {dict_complete_list}")
    return dict_complete_list

def extract_package_details(details):
    if details == "N/A" or details.lower() == "nan":
        return "N/A", "N/A", "N/A"
    package_name_match = re.search(r'Name:\s*([^<]+)', details)
    package_version_match = re.search(r'Version:\s*([^<]+)', details)
    package_paths_match = re.search(r'Paths:\s*([^<]+)', details)

    package_name = clean_field(package_name_match.group(1).strip()) if package_name_match else "N/A"
    package_version = clean_field(package_version_match.group(1).strip()) if package_version_match else "N/A"
    service_name = "N/A"
    if package_paths_match:
        package_paths = clean_field(package_paths_match.group(1).strip())
        if package_paths != "N/A":
            match_jar = re.search(r'/([^/]+\.jar)', package_paths)
            match_python = re.search(r'/python([\d\.]+)', package_paths)
            match_last = re.search(r'/([^/]+)$', package_paths)
            if match_jar:
                service_name = match_jar.group(1).replace('.jar', '')
            elif match_python:
                service_name = f"python{match_python.group(1)}"
            elif match_last:
                service_name = match_last.group(1)
    return package_name, package_version, service_name

def clean_field(value):
    if not isinstance(value, str) or value.lower() == "nan" or value == "N/A" or value == "":
        return "N/A"
    return value.strip('"')

