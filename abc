USERNAME = SECURITY_USERNAME
PASSWORD = SECURITY_PASSWORD

logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')
logger = logging.getLogger(__name__)

DEBUG_DIR = os.path.join("/tmp", "debug")
LOGIN_DOMAINS = ("login.microsoftonline.com", "login.windows.net", "login.live.com")

EXPORT_BUTTON_SELECTORS = [
    "button:has-text('Export')",
    "text=Export",
    "button:has-text('Download')",
    "[aria-label*='Export']",
    "[aria-label*='Download']",
    "[role='button']",
]

DASHBOARD_READY_SELECTORS = [
    "button:has-text('Export')",
    "text=Export",
    "button:has-text('Download')",
    "[aria-label*='Export']",
    "[aria-label*='Download']",
    "[role='button']",
