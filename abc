name: Deploy

on:
  workflow_call:
    inputs:
      environments:
        required: true
        type: string
      image-tag:
        required: true
        type: string


permissions:
  actions: read
  contents: write
  pull-requests: read
  security-events: write
  checks: write
  id-token: write

  
jobs:
  setup-environments:
    name: Setup Environments
    runs-on: uhg-runner
    outputs:
      environments: ${{ steps.reframe.outputs.environments }}
      contains-promotion-environment: ${{ steps.check-prod-environments.outputs.contains_promo }}
      promotion-environments: ${{ steps.check-prod-environments.outputs.promotion_environments }}
      docker-image-name: ${{ steps.app-config.outputs.app-name }}
      jfrog-project-key: ${{ steps.app-config.outputs.jfrog-project-key }}
      artifactory: ${{ steps.app-config.outputs.artifactory }}
      container-registry: ${{ steps.app-config.outputs.container-registry }}
    steps:
      - name: Checkout Code
        uses: actions/checkout@v4
      - name: Load App Config
        uses: uhc-tech-medicare-retiree-medicare/matrix-workflows/.github/actions/load-app-config@v2
        id: app-config
      - name: Check if environments contain any promotion environments
        id: check-prod-environments
        shell: bash
        env:
          INPUT_ENVIRONMENTS: ${{ inputs.environments }}
          PROMOTION_ENVIRONMENTS: ${{ steps.app-config.outputs.promotion-environments }}
          PROD_ENVIRONMENTS: ${{ steps.app-config.outputs.prod-environments }}
        # Use promotion-environments if exists, otherwise fall back to prod-environments
        # Collect all input environments that require promotion
        run: |
          IFS=',' read -a input_envs_array <<< "$INPUT_ENVIRONMENTS"
          
          # Determine which environments to use for promotion
          # Priority: promotion-environments > prod-environments
          if [ -n "$PROMOTION_ENVIRONMENTS" ]; then
            echo "Using promotion-environments: ${PROMOTION_ENVIRONMENTS}"
            IFS=',' read -a target_envs_array <<< "$PROMOTION_ENVIRONMENTS"
          else
            echo "Falling back to prod-environments: ${PROD_ENVIRONMENTS}"
            IFS=',' read -a target_envs_array <<< "$PROD_ENVIRONMENTS"
          fi
          
          contains_promo='false'
          promotion_environments=()
          
          # Collect all input environments that match target environments
          for input_env in "${input_envs_array[@]}"; do
            input_env=$(echo "$input_env" | xargs)
            for target_env in "${target_envs_array[@]}"; do
              target_env=$(echo "$target_env" | xargs)
              if [[ "$input_env" == "$target_env" ]]; then
                contains_promo='true'
                promotion_environments+=("$input_env")
              fi
            done
          done
          
          # Convert array to JSON array format for matrix strategy
          promotion_envs_json=$(printf '%s\n' "${promotion_environments[@]}" | jq -R . | jq -s -c .)
          
          echo "contains_promo=${contains_promo}" >> $GITHUB_OUTPUT
          echo "promotion_environments=${promotion_envs_json}" >> $GITHUB_OUTPUT
          echo "Contains promotion environment: ${contains_promo}"
          echo "Promotion environments: ${promotion_environments[*]}"
      - name: Reframe Environments as JSON array
        id: reframe
        # Convert the comma separated environments field to a JSON array 
        # that can be used as matrix strategy
        shell: bash
        env:
          ENVS_COMMA_SEPARATED: ${{ inputs.environments }}
        # jq --raw-input reads the input as string instead of json
        # jq --compact-output outputs the json in a single line
        run: |
          echo "Environments: ${ENVS_COMMA_SEPARATED}"
          environments_json=$(echo "${ENVS_COMMA_SEPARATED}" | jq --raw-input --compact-output 'split(",")')
          echo "environments_json: ${environments_json}"
          echo "environments=${environments_json}" >> $GITHUB_OUTPUT
    
  promote-azure-cr-image:
    if: ${{ endsWith(needs.setup-environments.outputs.container-registry, 'azurecr.io') && needs.setup-environments.outputs.contains-promotion-environment == 'true' }}
    name: Promote Azure Container Registry Image - ${{ matrix.environment }}
    uses: uhc-tech-medicare-retiree-medicare/matrix-workflows/.github/workflows/promote-azure-cr-image.yaml@v2
    needs: setup-environments
    strategy:
      fail-fast: false
      matrix:
        environment: ${{ fromJson(needs.setup-environments.outputs.promotion-environments) }}
    with:
      tag: ${{ inputs.image-tag }}
      environment: ${{ matrix.environment }}

  promote-repo1-image:
    if: ${{ endsWith(needs.setup-environments.outputs.container-registry, 'repo1.uhc.com') && needs.setup-environments.outputs.contains-promotion-environment == 'true' }}
    name: Promote Repo1 Image
    uses: uhc-tech-medicare-retiree-medicare/matrix-workflows/.github/workflows/promote-repo1-image.yaml@v2
    needs: setup-environments
    with:
      tag: ${{ inputs.image-tag }}
      environment: ${{ fromJson(needs.setup-environments.outputs.promotion-environments)[0] }}

  promote-jfrog-saas-image:
    if: ${{ !endsWith(needs.setup-environments.outputs.container-registry, 'azurecr.io') && !endsWith(needs.setup-environments.outputs.container-registry, 'repo1.uhc.com') && needs.setup-environments.outputs.contains-promotion-environment == 'true' }}
    name: Promote JFrog-Saas Image
    uses: uhg-pipelines/privileged-workflows/.github/workflows/promote-docker-image.yaml@v2
    needs: setup-environments
    with:
      jfrog-project-key: ${{ needs.setup-environments.outputs.jfrog-project-key }}
      source-docker-image-name: ${{ needs.setup-environments.outputs.docker-image-name }}
      source-docker-image-tag: ${{ inputs.image-tag }}
      promotion-type: release

  deploy:
    runs-on: uhg-runner
    needs: 
      - setup-environments
      - promote-azure-cr-image
      - promote-repo1-image
      - promote-jfrog-saas-image
    # Run if workflow is not cancelled and either:
    # - contains-promotion-environment is false
    # - or one of the promote jobs succeeded
    if: ${{ !cancelled() && (needs.setup-environments.outputs.contains-promotion-environment == 'false' || needs.promote-azure-cr-image.result == 'success' || needs.promote-repo1-image.result == 'success' || needs.promote-jfrog-saas-image.result == 'success') }}
    strategy:
      # Failure to deploy to one environment should not cancel other deployments
      fail-fast: false
      matrix:
        environment: ${{ fromJson(needs.setup-environments.outputs.environments) }}
    name: Deploy to ${{ matrix.environment }}
    environment: ${{ matrix.environment }}
    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Load App Config
        uses: uhc-tech-medicare-retiree-medicare/matrix-workflows/.github/actions/load-app-config@v2
        id: app-config

      - name: Fetch Secrets
        uses: uhc-tech-medicare-retiree-medicare/matrix-workflows/.github/actions/fetch-secrets@v2
        with:
          environment: ${{ matrix.environment }}

      - name: Deploy Azure Container App
        if: ${{ steps.app-config.outputs.deployment-platform == 'azure-container-app' }}  
        uses: uhc-tech-medicare-retiree-medicare/matrix-workflows/.github/actions/deploy-azure-container-app@v2
        with:
          azure-credentials: ${{ env.DS_AZURE_CREDENTIALS }}
          target-environment: ${{ matrix.environment }}
          image-tag: ${{ inputs.image-tag }}

      - name: Deploy Azure Container App Job
        if: ${{ steps.app-config.outputs.deployment-platform == 'azure-container-app-job' }}  
        uses: uhc-tech-medicare-retiree-medicare/matrix-workflows/.github/actions/deploy-azure-container-app-job@v2
        with:
          azure-credentials: ${{ env.DS_AZURE_CREDENTIALS }}
          target-environment: ${{ matrix.environment }}
          image-tag: ${{ inputs.image-tag }}

      - name: Deploy Azure Function App
        if: ${{ steps.app-config.outputs.deployment-platform == 'azure-function-app' }}
        uses: uhc-tech-medicare-retiree-medicare/matrix-workflows/.github/actions/deploy-azure-function-app@v2
        with:
          azure-credentials: ${{ env.DS_AZURE_CREDENTIALS }}
          target-environment: ${{ matrix.environment }}
          image-tag: ${{ inputs.image-tag }}

      - name: Deploy to HCC Kubernetes
        if: ${{ steps.app-config.outputs.deployment-platform == 'hcc-kubernetes'}}
        id: deploy-hcc-kubernetes
        uses: uhc-tech-medicare-retiree-medicare/matrix-workflows/.github/actions/deploy-hcc-kubernetes@v2
        with:
          target-environment: ${{ matrix.environment }}
          image-tag: ${{ inputs.image-tag }}
          cluster-token: ${{ env.DS_KUBERNETES_TOKEN }}
          cluster-ca-cert: ${{ env.DS_KUBERNETES_CERT }}

      - name: Deploy to Azure Kubernetes Service
        if: ${{ steps.app-config.outputs.deployment-platform == 'azure-kubernetes-service' }}
        id: deploy-aks
        uses: uhc-tech-medicare-retiree-medicare/matrix-workflows/.github/actions/deploy-to-aks@v2
        with:
          azure-credentials: ${{ env.DS_AZURE_CREDENTIALS }}
          target-environment: ${{ matrix.environment }}
          image-tag: ${{ inputs.image-tag }}
          image-name: ${{ needs.setup-environments.outputs.docker-image-name }}

