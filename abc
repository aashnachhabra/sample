# CLEAN DIR
# ---------------------------------------------------------------------------

def delete_old_files(download_dir):
    if not os.path.exists(download_dir):
        return
    for f in os.listdir(download_dir):
        path = os.path.join(download_dir, f)
        try:
            if os.path.isfile(path):
                os.remove(path)
            else:
                shutil.rmtree(path)
        except Exception as e:
            logger.error(f"Failed deleting {path}: {e}")

# ---------------------------------------------------------------------------
# RETRY
# ---------------------------------------------------------------------------

def retry(max_retries=3, delay=10):
    def decorator(func):
        def wrapper(*args, **kwargs):
            for attempt in range(max_retries):
                try:
                    return func(*args, **kwargs)
                except Exception as e:
                    logger.error(f"{func.__name__} failed (attempt {attempt+1}): {e}")
                    if attempt == max_retries - 1:
                        raise
                    time.sleep(delay * (attempt + 1))
        return wrapper
    return decorator

# ---------------------------------------------------------------------------
# DASHBOARD + DOWNLOAD
# ---------------------------------------------------------------------------

def wait_for_dashboard(page):
    logger.info("⏳ Waiting for dashboard to load...")
    logger.info(f"🌐 Current URL before dashboard wait: {page.url}")

    try:
        title = page.title()
        logger.info(f"📄 Page title: {title}")
    except:
        pass

    try:
        matched = _wait_any_selector(page, DASHBOARD_READY_SELECTORS, timeout_ms=90000)
        logger.info(f"✅ Dashboard loaded (matched: {matched})")
    except Exception:
        logger.error(f"❌ Dashboard NOT loaded. URL: {page.url}")
        _capture(page, "dashboard-timeout")
        raise

def download_file(page, download_dir):
    logger.info("⬇️  Clicking Export...")
    matched = _wait_any_selector(page, EXPORT_BUTTON_SELECTORS, timeout_ms=90000)
    btn = page.locator(matched).first
    try:
        btn.scroll_into_view_if_needed(timeout=5000)
    except Exception:
        pass
    with page.expect_download() as d:
        btn.click(timeout=10000)
    file = d.value
    path = os.path.join(download_dir, file.suggested_filename)
    file.save_as(path)
    logger.info(f"✅ Downloaded: {path}")

