@retry()
def process_url(page, url, download_dir):
    logger.info(f"🌐 Opening {url}")
    page.goto(url)
    page.wait_for_timeout(5000)
    # Wait for the full redirect chain to settle before checking login state
    try:
        page.wait_for_load_state("networkidle", timeout=15000)
    except Exception:
        pass

    ensure_logged_in(page, target_url=url)
    # Some runs bounce back to login after ensure_logged_in due delayed redirects.
    if _is_login_page(page):
        logger.info("🔁 Redirected back to login domain after auth check; retrying login once")
        azure_login(page, target_url=url)
        page.wait_for_timeout(5000)
        logger.info(f"✅ After retry login landed on: {page.url}")
    wait_for_dashboard(page)
    download_file(page, download_dir)

